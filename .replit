modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/health-chat-assistant run dev & node scripts/dev-proxy.mjs"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 19579
externalPort = 3001

[userenv]

[userenv.shared]
ENABLE_OPENAI = "true"
AI_PROVIDER = "openai"
JWT_ACCESS_SECRET = "9eb7b94d77020997ad132659d9c20b0d898e2dd04973e8bfdfb70059b1b8c32a0bbe18b2601359322a952ab60d2e1d68"
JWT_REFRESH_SECRET = "eddd76e5f2402c21e9fd61944e3ea2db49719be85c1754f35e3066923519a3b211b4e7425e3c42976217ac696c17a2c0"
PORT = "8080"

[nix]
channel = "stable-25_05"
