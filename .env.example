# MediNova — Environment Variables Template
# -------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to Git.
# -------------------------------------------------

# MongoDB Atlas connection string
MONGODB_URI=

# JWT signing secrets (use long random strings, 32+ characters)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# AI configuration
ENABLE_OPENAI=false
AI_PROVIDER=mock
